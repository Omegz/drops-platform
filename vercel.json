{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm build",
  "outputDirectory": "apps/driver-app/dist",
  "cleanUrls": true,
  "functions": {
    "api/route.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/v1",
      "destination": "/api/route?path=v1"
    },
    {
      "source": "/api/v1/:path*",
      "destination": "/api/route?path=v1/:path*"
    },
    {
      "source": "/track/:token",
      "destination": "/track/[token]"
    }
  ]
}
